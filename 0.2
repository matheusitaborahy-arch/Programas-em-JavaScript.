// O nome não muda, usamos const. Idade e energia podem mudar, usamos let.
const nomePersonagem = "Arthur";
let idadePersonagem = 25;
let nivelEnergia = 100;

console.log(`O herói ${nomePersonagem} tem ${idadePersonagem} anos e sua energia atual é ${nivelEnergia}.`);





let carteira = 50;

// Encontrou 5 reais
carteira += 5; 

// Comprou um lanche de 12 reais
carteira -= 12; 

console.log(`O valor final que sobrou na carteira é R$ ${carteira}.`);





