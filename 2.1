// 1. Criar o objeto 'produto'
const produto = {
  nome: 'Notebook',
  precoOriginal: 3500.00,
  desconto: 0.15 // Representa 15%
};

// 2. Exibir no console o nome e o preço original
console.log(`Produto: ${produto.nome} - R$ ${produto.precoOriginal.toFixed(2)}`);

// 3. (Desafio) Adicionar o método 'calcularPrecoFinal'
produto.calcularPrecoFinal = function() {
  const valorDesconto = this.precoOriginal * this.desconto;
  return this.precoOriginal - valorDesconto;
};

// 4. Chamar o método no console para ver o resultado
const precoFinal = produto.calcularPrecoFinal();
console.log(`Preço final com desconto: R$ ${precoFinal.toFixed(2)}`);
